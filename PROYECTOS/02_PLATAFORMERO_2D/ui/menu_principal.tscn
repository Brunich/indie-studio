[gd_scene load_steps=2 format=3 uid="uid://c9menu_principal01"]

[ext_resource type="Script" path="res://ui/menu_principal.gd" id="1_menu"]

;; menu_principal.tscn — Menú principal del plataformero 2D
;; Estructura:
;;   Control (raíz, pantalla completa, con script menu_principal.gd)
;;   ├─ BG              — ColorRect de fondo (gris oscuro)
;;   ├─ VBox            — VBoxContainer centrado con los 3 botones principales
;;   │   ├─ LabelTitulo — Título del juego
;;   │   ├─ BtnJugar
;;   │   ├─ BtnMultijugador
;;   │   └─ BtnSalir
;;   └─ PanelMultijugador — Panel oculto por defecto con opciones de red
;;       └─ VBoxMulti
;;           ├─ LabelMulti   — "Multijugador"
;;           ├─ InputIP      — LineEdit para la IP
;;           ├─ BtnHost
;;           └─ BtnUnirse

[node name="MenuPrincipal" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_menu")

[node name="BG" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.08, 0.12, 1.0)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -120.0
offset_top = -110.0
offset_right = 120.0
offset_bottom = 110.0
theme_override_constants/separation = 12

[node name="LabelTitulo" type="Label" parent="VBox"]
layout_mode = 2
size_flags_horizontal = 4
horizontal_alignment = 1
text = "PLATAFORMERO 2D"
theme_override_font_sizes/font_size = 28

[node name="BtnJugar" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(240, 44)
text = "Jugar"

[node name="BtnMultijugador" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(240, 44)
text = "Multijugador"

[node name="BtnSalir" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(240, 44)
text = "Salir"

[node name="PanelMultijugador" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = 125.0
offset_right = 150.0
offset_bottom = 285.0
visible = false

[node name="VBoxMulti" type="VBoxContainer" parent="PanelMultijugador"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="LabelMulti" type="Label" parent="PanelMultijugador/VBoxMulti"]
layout_mode = 2
horizontal_alignment = 1
text = "— Multijugador —"

[node name="InputIP" type="LineEdit" parent="PanelMultijugador/VBoxMulti"]
layout_mode = 2
placeholder_text = "IP del servidor (ej: 192.168.1.10)"
text = ""

[node name="BtnHost" type="Button" parent="PanelMultijugador/VBoxMulti"]
layout_mode = 2
text = "Crear partida (Host)"

[node name="BtnUnirse" type="Button" parent="PanelMultijugador/VBoxMulti"]
layout_mode = 2
text = "Unirse a partida"
