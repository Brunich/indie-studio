[gd_scene load_steps=2 format=3 uid="uid://c3h8xnplat2dhud"]

[ext_resource type="Script" path="res://ui/hud.gd" id="1_hud"]

;; HUD del plataformero 2D
;; Estructura:
;;   CanvasLayer (layer=10, con script hud.gd)
;;   └─ TopHBox  ──  HBoxContainer pegado al borde superior
;;       ├─ LabelScore   (izquierda)
;;       ├─ SpacerL      (expansor)
;;       ├─ LabelRound   (centro)
;;       ├─ SpacerR      (expansor)
;;       └─ LabelLives   (derecha)

[node name="HUD" type="CanvasLayer"]
layer = 10
script = ExtResource("1_hud")

[node name="TopHBox" type="HBoxContainer" parent="."]
anchor_right = 1.0
offset_bottom = 40.0
theme_override_constants/separation = 8

[node name="LabelScore" type="Label" parent="TopHBox"]
layout_mode = 2
size_flags_horizontal = 4
text = "Score: 0"
vertical_alignment = 1

[node name="SpacerL" type="Control" parent="TopHBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="LabelRound" type="Label" parent="TopHBox"]
layout_mode = 2
size_flags_horizontal = 4
horizontal_alignment = 1
text = "Ronda: 1"
vertical_alignment = 1

[node name="SpacerR" type="Control" parent="TopHBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="LabelLives" type="Label" parent="TopHBox"]
layout_mode = 2
size_flags_horizontal = 4
horizontal_alignment = 2
text = "❤️ x3"
vertical_alignment = 1
